{
  "name": "custos-gait-awareness",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Privacy-preserving multimodal gait-change awareness research prototype.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run test:run && npm run build"
  },
  "dependencies": {
    "express": "^5.1.0",
    "openai": "^6.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
